{
  "name": "cpin",
  "displayName": "cpin",
  "description": "Visual Studio Extension for cpin cli ",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.cpin"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cpin.addNote",
        "title": "cpin: Add Note"
      },
      {
        "command": "cpin.removeNote",
        "title": "cpin: Remove Note"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "cpin.addNote",
          "group": "cpin@1",
          "when": "editorFocus"
        },
        {
          "command": "cpin.removeNote",
          "group": "cpin@2",
          "when": "editorFocus"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
